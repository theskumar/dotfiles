// Static tasks configuration.
//
// Example:
[
  {
    "label": "Yazi File Explorer",
    "command": "EDITOR='zed' yazi",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "center",
    "hide": "on_success",
    "shell": {
      "with_arguments": {
        "program": "sh",
        "args": ["--noediting", "--norc", "--noprofile"],
      },
    },
  },
  {
    "label": "Open Helix",
    "command": "hx .",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "center",
    "hide": "on_success",
    "shell": {
      "with_arguments": {
        "program": "sh",
        "args": ["--noediting", "--norc", "--noprofile"],
      },
    },
  },
  {
    "label": "Open Claude Code",
    "command": "EDITOR=zed claude $ZED_WORKTREE_ROOT",
    "working_directory": "${ZED_WORKTREE_ROOT}",
    "use_new_terminal": true,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "reveal_target": "center",
    "hide": "on_success",
    "shell": "system",
  },
  {
    "label": "LazyGit",
    "command": "lazygit",
    "hide": "on_success",
    "reveal_target": "center",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "shell": {
      "with_arguments": {
        "program": "sh",
        "args": ["--noediting", "--norc", "--noprofile"],
      },
    },
  },
  {
    "label": "Markdown glow",
    "command": "mdglow \"$ZED_FILE\"",
    "reveal_target": "center",
    "show_summary": false,
    "show_command": false,
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "hide": "on_success",
    "shell": "system",
  },
  {
    "label": "make serve",
    "command": "source .venv/bin/activate; make serve",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "always",
    "hide": "never",
    "shell": "system",
  },
  {
    "label": "Television File Finder",
    "command": "zed \"$(tv files)\"",
    "hide": "always",
    "allow_concurrent_runs": true,
    "use_new_terminal": true,
    "shell": {
      "with_arguments": {
        "program": "sh",
        "args": ["--noediting", "--norc", "--noprofile"],
      },
    },
  },
  {
    "label": "Live Grep",
    "command": "zed $(cs)",
    "hide": "always",
    "allow_concurrent_runs": true,
    "use_new_terminal": false,
    "shell": {
      "with_arguments": {
        "program": "sh",
        "args": ["--noediting", "--norc", "--noprofile"],
      },
    },
  },
  {
    "label": "Gist: Push",
    "command": "gist-sync",
    "args": ["push", "$ZED_FILE"],
    "use_new_terminal": false,
    "reveal": "always",
    "tags": ["gist"],
  },
  {
    "label": "Gist: Push (private)",
    "command": "gist-sync",
    "args": ["push", "$ZED_FILE", "--private"],
    "use_new_terminal": false,
    "reveal": "always",
    "tags": ["gist"],
  },
  {
    "label": "Gist: Pull",
    "command": "gist-sync",
    "args": ["pull", "$ZED_FILE"],
    "use_new_terminal": false,
    "reveal": "always",
    "tags": ["gist"],
  },
  {
    "label": "Gist: Diff",
    "command": "gist-sync",
    "args": ["diff", "$ZED_FILE"],
    "use_new_terminal": false,
    "reveal": "always",
    "tags": ["gist"],
  },
  {
    "label": "Gist: Copy URL",
    "command": "gist-sync",
    "args": ["url", "$ZED_FILE"],
    "use_new_terminal": false,
    "reveal": "always",
    "tags": ["gist"],
  },
  {
    "label": "Gist: Unlink",
    "command": "gist-sync",
    "args": ["unlink", "$ZED_FILE"],
    "use_new_terminal": false,
    "reveal": "always",
    "tags": ["gist"],
  },
  {
    "label": "Markdown Preview",
    "command": "mdview \"$ZED_FILE\"",
    "use_new_terminal": false,
    "allow_concurrent_runs": true,
    "reveal": "never",
    "hide": "always",
    "shell": "system",
  },
  {
    "label": "Gist: List",
    "command": "gist-sync",
    "args": ["list"],
    "use_new_terminal": false,
    "reveal": "always",
    "tags": ["gist"],
  },
]

#!/usr/bin/env bash
# mdpdf-web - render markdown to PDF via headless Chromium (md-to-pdf).
# Uses github-markdown-css for styling, highlight.js (default) for code,
# and beautiful-mermaid (pre-rendered to inline SVG in Node, same renderer
# as mdview) for diagrams. Maximum GitHub fidelity (renders in real Chrome
# with the actual GitHub stylesheet).
#
# Usage:
#   mdpdf-web <file.md> [-o out.pdf] [-O|--open]
#                       [--theme light|dark] [--paper A4|Letter]
#                       [--margin 2cm] [--no-mermaid]
#
# Requires: node (>= 18) on PATH; `npx` auto-fetches md-to-pdf on first run.
# Network: required first run (npm cache) and for CDN-hosted CSS/mermaid.

set -euo pipefail

die() { echo "mdpdf-web: $*" >&2; exit 1; }

out=""
theme="light"
paper="A4"
margin="2cm"
use_mermaid=1
open_after=0
src=""

while [ $# -gt 0 ]; do
  case "$1" in
    -o|--output)   out="$2"; shift 2 ;;
    -O|--open)     open_after=1; shift ;;
    --theme)       theme="$2"; shift 2 ;;
    --paper)       paper="$2"; shift 2 ;;
    --margin)      margin="$2"; shift 2 ;;
    --no-mermaid)  use_mermaid=0; shift ;;
    -h|--help)     sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'; exit 0 ;;
    -*)            die "unknown flag: $1" ;;
    *)             [ -z "$src" ] && src="$1" || die "unexpected arg: $1"; shift ;;
  esac
done

[ -n "$src" ] && [ -f "$src" ] || die "usage: mdpdf-web <file.md> [-o out.pdf]"
command -v node >/dev/null || die "node not found"
command -v npx  >/dev/null || die "npx not found"

[ -z "$out" ] && out="${src%.*}.pdf"

case "$theme" in
  light) css_file="github-markdown-light.css"; theme_opts='{"bg":"#ffffff","fg":"#24292f"}' ;;
  dark)  css_file="github-markdown-dark.css";  theme_opts='{"bg":"#0d1117","fg":"#c9d1d9"}' ;;
  *)     die "unknown theme: $theme (light|dark)" ;;
esac

# Stage source into a work dir so md-to-pdf emits the PDF there (no --dest).
work="$(mktemp -d -t mdpdf-web.XXXXXX)"
trap 'rm -rf "$work"' EXIT

src_stem="$(basename "${src%.*}")"
cp "$src" "$work/$src_stem.md"

# Pre-render ```mermaid fences to inline SVG with beautiful-mermaid (the
# mdview renderer). Runs in Node before Chromium, so the PDF never races a
# CDN script. Failed diagrams keep their code block and print a warning.
if [ "$use_mermaid" -eq 1 ] && grep -q '^```mermaid' "$work/$src_stem.md"; then
  echo "mdpdf-web: pre-rendering mermaid diagrams..."
  ( cd "$work" \
      && npm init -y >/dev/null 2>&1 \
      && npm install --silent --no-audit --no-fund beautiful-mermaid >/dev/null )
  MDPDF_FILE="$work/$src_stem.md" MDPDF_THEME_OPTS="$theme_opts" node <<'NODE'
const fs = require("node:fs");
const path = require("node:path");
const file = process.env.MDPDF_FILE;
const bm = require(path.join(path.dirname(file), "node_modules", "beautiful-mermaid"));
const opts = JSON.parse(process.env.MDPDF_THEME_OPTS);
const src = fs.readFileSync(file, "utf8");
const out = src.replace(/```mermaid\r?\n([\s\S]*?)```[ \t]*\n/g, (block, code) => {
  try {
    const svg = bm.renderMermaidSVG(code.trim(), opts).replace(/\r?\n/g, " ");
    return '<div class="mermaid">' + svg + "</div>\n";
  } catch (e) {
    console.error("mdpdf-web: mermaid render failed, keeping code block:", e.message);
    return block;
  }
});
fs.writeFileSync(file, out);
NODE
fi

cat > "$work/config.js" <<CONFIG
const baseConfig = {
  stylesheet: [
    "https://cdn.jsdelivr.net/npm/github-markdown-css@5/${css_file}",
  ],
  body_class: "markdown-body",
  css: \`
    .markdown-body {
      box-sizing: border-box;
      max-width: 980px;
      margin: 0 auto;
      padding: 0;
      font-size: 14px;
    }
    .mermaid { background: transparent; text-align: center; margin: 1em 0; }
    .mermaid svg { max-width: 100%; height: auto; }
  \`,
  marked_options: { gfm: true, breaks: false },
  pdf_options: {
    format: "${paper}",
    margin: { top: "${margin}", bottom: "${margin}", left: "${margin}", right: "${margin}" },
    printBackground: true,
  },
  launch_options: { args: ["--no-sandbox", "--font-render-hinting=none"] },
};

module.exports = baseConfig;
CONFIG

echo "mdpdf-web: rendering (first run may install md-to-pdf)..."
( cd "$work" && npx -y md-to-pdf --config-file ./config.js "./$src_stem.md" >/dev/null )

generated="$work/$src_stem.pdf"
[ -f "$generated" ] || die "render failed: $generated not produced"
mv "$generated" "$out"

echo "mdpdf-web: $src -> $out"

if [ "$open_after" -eq 1 ]; then
  if   command -v open    >/dev/null; then open "$out"
  elif command -v xdg-open >/dev/null; then xdg-open "$out" >/dev/null 2>&1 &
  fi
fi

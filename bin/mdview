#!/usr/bin/env bash
# mdview - render a markdown file to HTML and open in the default browser.
# Usage: mdview <file.md>
set -euo pipefail

if [ $# -eq 0 ] || [ ! -f "$1" ]; then
  echo "usage: mdview <file.md>" >&2
  exit 1
fi

src="$1"
name="$(basename "$src")"
out="${TMPDIR:-/tmp}/mdview-${name%.*}.html"

css='
:root { color-scheme: light dark; }
html { background: #ffffff; }
body {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  max-width: 860px; margin: 2rem auto; padding: 0 1.5rem;
  line-height: 1.6; color: #24292f; background: #ffffff;
}
h1, h2 { border-bottom: 1px solid #d0d7de; padding-bottom: .3em; }
code { background: #f6f8fa; padding: .2em .4em; border-radius: 6px; font-size: 85%; }
pre { background: #f6f8fa; padding: 1em; border-radius: 6px; overflow-x: auto; }
pre code { background: transparent; padding: 0; }
div.sourceCode { background: #f6f8fa; border-radius: 6px; }
blockquote { color: #57606a; border-left: .25em solid #d0d7de; padding: 0 1em; margin: 0; }
table { border-collapse: collapse; }
th, td { border: 1px solid #d0d7de; padding: 6px 13px; }
img { max-width: 100%; }
hr { border: 0; border-top: 1px solid #d0d7de; }
@media (prefers-color-scheme: dark) {
  html { background: #0d1117; }
  body { color: #c9d1d9; background: #0d1117; }
  a { color: #58a6ff; }
  code { background: #161b22; }
  pre { background: #161b22; }
  pre code { background: transparent; color: #c9d1d9; }
  div.sourceCode { background: #161b22; }
  blockquote { color: #8b949e; border-left-color: #30363d; }
  hr, table, th, td { border-color: #30363d; }
}
'

header="$(mktemp -t mdview-css.XXXXXX)"
footer="$(mktemp -t mdview-js.XXXXXX)"
trap 'rm -f "$header" "$footer"' EXIT
printf '<style>%s</style>\n' "$css" > "$header"

cat > "$footer" <<'EOF'
<style>
pre.mermaid { background: transparent; padding: 0; }
</style>
<script type="module">
import { renderMermaidSVG } from 'https://esm.sh/beautiful-mermaid';
const dark = window.matchMedia('(prefers-color-scheme: dark)').matches;
const opts = dark ? { bg: '#0d1117', fg: '#c9d1d9' } : { bg: '#ffffff', fg: '#24292f' };
document.querySelectorAll('pre.mermaid').forEach(pre => {
  const code = pre.querySelector('code');
  const text = (code ?? pre).textContent.trim();
  try {
    const svg = renderMermaidSVG(text, opts);
    pre.innerHTML = svg;
  } catch (e) {
    pre.textContent = text;
    console.error('mermaid render error:', e);
  }
});
</script>
EOF

pandoc \
  --standalone \
  --from gfm \
  --to html5 \
  --metadata title="$name" \
  --include-in-header="$header" \
  --include-after-body="$footer" \
  "$src" -o "$out"

open "$out"
